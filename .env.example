# Copie a .env y ajuste valores (nunca commitee .env)
#
# Dockge: si solo pegó el compose y no clonó el repo, NO ponga BUILD_CONTEXT (usa GitHub).
# Si clonó el proyecto en la carpeta del stack: BUILD_CONTEXT=. (punto = directorio actual)

POSTGRES_PASSWORD=cambie_esta_clave_larga
# BUILD_CONTEXT=.
API_PORT=8000

# Sesión y CSRF (generar: openssl rand -hex 32)
SESSION_SECRET=
CSRF_SECRET=

# El primer usuario administrador se crea en la web: /setup (sin INITIAL_* en .env)
# WHM / SSH: valores por defecto; puede sobreescribirlos en el panel: /settings/integrations (admin)
WHM_SSH_HOST=203.0.113.10
WHM_SSH_USER=root
WHM_SSH_PORT=22
# Ruta a clave privada montada en el contenedor (compose volume)
WHM_SSH_KEY_PATH=/secrets/whm_rsa
WHM_STAGING_PATH=/home/backup
WHM_RESTORE_INCOMING=/root/incoming_restore

# Google Drive / rclone (nombre del remote y prefijo remoto)
RCLONE_REMOTE=gdrive
DRIVE_REMOTE_PREFIX=WHM03_BACKUP

# Webhook hook PkgAcct (opcional)
WEBHOOK_HMAC_SECRET=

# Worker
WORKER_POLL_ACTIVE_SECONDS=120
WORKER_POLL_IDLE_SECONDS=900
FILE_STABLE_SECONDS=180
DRAIN_MAX_RETRIES=5
DRAIN_RETRY_BASE_SECONDS=60

# Alertas (webhook genérico HTTP POST JSON)
ALERT_WEBHOOK_URL=

# Restore WHM API (opcional; permisos elevados)
WHM_API_HOST=https://203.0.113.10:2087
WHM_API_TOKEN=
