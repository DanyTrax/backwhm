# Copie a .env del stack (Dockge) o del proyecto local. No commitee .env.
#
# Mínimo en Dockge: POSTGRES_PASSWORD (+ API_PORT si no usa 8000).
# Dockge build desde Git: no defina BUILD_CONTEXT. Con repo en la carpeta: BUILD_CONTEXT=.
#
# SESSION_SECRET / CSRF_SECRET: opcionales; la app genera sesión en BD (app_secrets).
# WEBHOOK_HMAC_SECRET: opcional; puede generarlo en /install o dejarlo vacío.

POSTGRES_PASSWORD=cambie_esta_clave_larga
# BUILD_CONTEXT=.
API_PORT=8000

SESSION_SECRET=
CSRF_SECRET=

# Valores por defecto; el panel admin → Integraciones los sustituye si los rellena.
WHM_SSH_HOST=203.0.113.10
WHM_SSH_USER=root
WHM_SSH_PORT=22
WHM_SSH_KEY_PATH=/secrets/whm_rsa
WHM_STAGING_PATH=/home/backup
WHM_RESTORE_INCOMING=/root/incoming_restore

RCLONE_REMOTE=gdrive
DRIVE_REMOTE_PREFIX=WHM03_BACKUP

WEBHOOK_HMAC_SECRET=

WORKER_POLL_ACTIVE_SECONDS=120
WORKER_POLL_IDLE_SECONDS=900
FILE_STABLE_SECONDS=180
DRAIN_MAX_RETRIES=5
DRAIN_RETRY_BASE_SECONDS=60

ALERT_WEBHOOK_URL=

WHM_API_HOST=https://203.0.113.10:2087
WHM_API_TOKEN=
